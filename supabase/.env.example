# Copy to `.env.local` (git-ignored) and fill in before running the Supabase CLI.
# These are needed only for LOCAL/credentialed CLI work (link, db pull, db push);
# the deployed static site needs none of them.

# Personal access token — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Database password for project ohnsawydclmsrgphasbn (Dashboard → Settings →
# Database). Used by `supabase link` / `supabase db pull` / `supabase db push`.
# Never commit the real value.
SUPABASE_DB_PASSWORD=
